---
import "../styles/global.css";
const { title = "Drew Reed", activePage } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Drew Reed — Graphic & Web Designer based in Indianapolis."
    />
    <title>{title} | Drew Reed</title>

    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Drew Reed" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
  </head>
  <body>
    <div class="site-wrapper">
      <header class="nav-header">
        <div class="nav-rule-top"></div>
        <div class="nav-eyebrow">
          Graphic &amp; Web Design — Indianapolis, IN
        </div>
        <a href="/" class="nav-name-link">
          <h1 class="nav-name">Drew Reed</h1>
        </a>
        <nav class="nav-links">
          <a
            href="/work"
            class={`nav-link${activePage === "work" ? " active" : ""}`}>Work</a
          >
          <a
            href="/about"
            class={`nav-link${activePage === "about" ? " active" : ""}`}
            >About</a
          >
          <a
            href="/blog"
            class={`nav-link${activePage === "blog" ? " active" : ""}`}>Blog</a
          >
          <a
            href="/contact"
            class={`nav-link${activePage === "contact" ? " active" : ""}`}
            >Contact</a
          >
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer-note">
        <div class="footer-rule">
          <span class="footer-ornament">&#9672;</span>
        </div>
        <div class="footer-text">
          Copyright &copy; 2026 Drew Reed &nbsp;&middot;&nbsp; All rights
          reserved.&nbsp;
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  .nav-name-link {
    text-decoration: none;
    display: block;
  }
</style>
