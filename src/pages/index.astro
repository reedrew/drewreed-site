---
import Base from "../layouts/Base.astro";

const featuredProject = {
    title: "The Knowledge Vault Intranet",
    type: "Web Design",
    image: "/images/projects/Knowledge_Vault/kv-featured-thumb.webp",
    alt: "The Knowledge Vault — Intranet Redesign",
    href: "/work#knowledge-vault",
};

const previewProjects = [
    {
        title: "Crazy Charlie's Salsa",
        type: "Graphic Design",
        image: "/images/projects/CCS/ccsalsa-thumb.webp",
        alt: "Crazy Charlie's Salsa redesign",
        href: "/work#crazy-charlies-salsa",
    },
    {
        title: "Hot & Knotty",
        type: "Print",
        image: "/images/projects/HnK/hot-n-knotty-thumb.webp",
        alt: "Hot & Knotty print",
        href: "/work#hot-and-knotty",
    },
    {
        title: "Cosmic Curiosities",
        type: "Graphic Design",
        image: "/images/projects/Cosmic_Curiosities/cosmic-cur-thumb.webp",
        alt: "Cosmic Curiosities",
        href: "/work#cosmic-curiosities",
    },
];
---

<Base title="Home" activePage="home">
    <section class="hero">
        <div class="hero-left">
            <!-- <div class="hero-issue">Est. 2024</div> -->
            <h2 class="hero-headline">Hey! I'm <em>Drew</em>.</h2>
            <p class="hero-body">
                I'm a graphic and web designer based in Indy. Here, you can
                check out what I'm working on and some of my favorite projects.
                I'm currently open to freelance work!
            </p>
            <a
                href="/work"
                class="hero-cta animate__animated stamp stamp-accent"
                ><strong>All my stuff ➜</strong></a
            >
        </div>
        <div class="hero-right">
            <div class="featured-label">Featured</div>
            <a href={featuredProject.href} class="featured-work">
                <img src={featuredProject.image} alt={featuredProject.alt} />
            </a>
            <div class="work-meta">
                <span class="work-title">{featuredProject.title}</span>
                <span class="work-type">{featuredProject.type}</span>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="section-header">
            <span class="page-title">Some Favorites</span>
            <div class="page-rule"></div>
            <span class="page-sub">01 — 03</span>
        </div>
        <div class="preview-grid">
            {
                previewProjects.map((project) => (
                    <a href={project.href} class="preview-item">
                        <div class="preview-thumb">
                            <img src={project.image} alt={project.alt} />
                        </div>
                        <div class="preview-item-title">{project.title}</div>
                        <div class="preview-item-cat">{project.type}</div>
                    </a>
                ))
            }
        </div>
        <div class="view-all-wrap">
            <a href="/work" class="view-all-link">All My Stuff ➜</a>
        </div>
    </section>
</Base>

<style>
    .hero {
        padding: 4rem 0 3rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: start;
        border-bottom: 0.1rem solid var(--rule);
    }

    .hero-issue {
        font-family: var(--font-mono);

        font-size: 1em;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .hero-issue::before,
    .hero-issue::after {
        content: "";
        display: inline-block;
        height: 0.15rem;
        width: 2.4rem;
        background: var(--accent);
    }

    .hero-headline {
        font-family: var(--font-wacky);
        font-size: 6rem;
        font-weight: 500;
        line-height: 1.05;
        color: var(--ink);
        text-shadow:
            0.1rem 0.1rem 0 rgba(44, 32, 21, 0.06),
            0.2rem 0.2rem 0 rgba(44, 32, 21, 0.03);
        margin: 1.25rem 0;
    }

    .hero-headline em {
        font-style: normal;
        color: var(--accent);
    }

    .hero-body {
        font-size: 1.75rem;
        line-height: 1.8;
        color: var(--ink-light);
        margin-bottom: 1.5rem;
        letter-spacing: 5%;
    }

    .hero-cta {
        display: inline-block;
        font-family: var(--font-serif);
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        border: 0.2em solid var(--accent);
        box-shadow:
            0 0.5rem 1.2rem rgba(44, 32, 21, 0.25),
            0 0.15rem 0.3rem rgba(44, 32, 21, 0.15);
        transition: all 0.15s;
        animation: swing;
        animation-duration: 2s;
        animation-delay: 3s;
    }

    .hero-cta:hover {
        transform: scale(1.02);
        box-shadow:
            0 0.9rem 1.2rem rgba(44, 32, 21, 0.25),
            0 0.45rem 0.3rem rgba(44, 32, 21, 0.15);
    }

    .hero-cta:active {
        box-shadow: none;
        background: var(--accent);
        color: var(--paper);
        scale: 0.99;
        /*border: var(--paper);*/
    }

    .hero-right {
        padding-top: 0.5rem;
    }

    .featured-label {
        font-family: var(--font-serif);
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink);
        margin-bottom: 0.75rem;
        border-bottom: 0.1rem solid var(--rule);
        padding-bottom: 0.5rem;
    }

    .featured-work {
        display: block;
        border: 0.1rem solid rgba(44, 32, 21, 0.1);
        aspect-ratio: 4/3;
        overflow: hidden;
        margin-bottom: 0.75rem;
        transition:
            border-color 0.15s,
            transform 0.2s ease-out,
            box-shadow 0.2s ease-out;
        background: rgba(44, 32, 21, 0.04);
    }

    .featured-work:hover {
        border-color: var(--accent);
        transform: scale(1.01);
        box-shadow:
            0 0.5rem 1.2rem rgba(44, 32, 21, 0.14),
            0 0.15rem 0.3rem rgba(44, 32, 21, 0.08);
    }

    .featured-work img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .work-meta {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }

    .work-title {
        font-family: var(--font-serif);
        font-size: 1.6rem;
        font-weight: 600;
        letter-spacing: 5%;
        color: var(--ink);
    }

    .work-type {
        font-family: var(--font-mono);
        font-size: 1rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
    }

    .section {
        padding: 3rem 0;
        border-bottom: 0.1rem solid var(--rule);
    }

    .section-header {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .preview-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .preview-item {
        text-decoration: none;
    }

    .preview-thumb {
        border: 0.1rem solid rgba(44, 32, 21, 0.1);
        aspect-ratio: 3/2;
        overflow: hidden;
        margin-bottom: 0.6rem;
        transition:
            border-color 0.15s,
            transform 0.2s ease-out,
            box-shadow 0.2s ease-out;
        background: rgba(44, 32, 21, 0.04);
    }

    .preview-item:hover .preview-thumb {
        border-color: var(--accent);
        transform: translateY(-0.3rem);
        box-shadow:
            0 0.5rem 1.2rem rgba(44, 32, 21, 0.14),
            0 0.15rem 0.3rem rgba(44, 32, 21, 0.08);
    }
    .preview-item:hover .preview-item-title {
        color: var(--accent);
    }

    .preview-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .preview-item-title {
        font-family: var(--font-serif);
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 0.2rem;
        transition: color 0.15s;
    }

    .preview-item-cat {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ochre);
    }

    .view-all-wrap {
        text-align: right;
    }

    .view-all-link {
        font-family: var(--font-serif);
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        transition: 0.3s;
    }

    .view-all-link:hover {
        color: var(--ink);
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .hero-headline {
            font-size: 4.2rem;
        }
        .preview-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 1.2rem;
        }
    }

    @media (max-width: 768px) {
        .hero {
            grid-template-columns: 1fr;
            gap: 2rem;
            padding: 3rem 0 2rem;
        }

        .hero-right {
            padding-top: 0;
        }

        .hero-headline {
            font-size: 3.8rem;
        }

        .preview-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .hero-headline {
            font-size: 3.2rem;
        }
        .hero-body {
            font-size: 1.4rem;
        }
        .preview-grid {
            grid-template-columns: 1fr;
        }
        .featured-label {
            font-size: 0.9rem;
        }
    }
</style>
