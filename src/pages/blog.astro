---
import Base from '../layouts/Base.astro';
---

<Base title="Blog" activePage="blog">

  <div class="page-content">
    <div class="page-header">
      <h2 class="page-title">Blog</h2>
      <div class="page-rule"></div>
    </div>

    <div class="empty-state">
      <div class="empty-ornament">Est. 2026</div>
      <h3 class="empty-headline">Nothing here, <em>yet.</em></h3>
      <p class="empty-body">Check back sometime.</p>
      <div class="stamp stamp-muted">Page intentionally left blank</div>
    </div>
  </div>
</Base>

<style>
  .page-content { padding: 4rem 0; }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 0 6rem;
  }

  .empty-ornament {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(44, 32, 21, 0.2);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .empty-ornament::before,
  .empty-ornament::after {
    content: '';
    display: inline-block;
    width: 4rem;
    height: 0.1rem;
    background: rgba(44, 32, 21, 0.15);
  }

  .empty-headline {
    font-family: var(--font-display);
    font-size: 3.8rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    text-shadow:
      0.1rem 0.1rem 0 rgba(44, 32, 21, 0.1),
      0.2rem 0.2rem 0 rgba(44, 32, 21, 0.05);
    max-width: 48rem;
  }

  .empty-headline em { font-style: italic; color: var(--accent); }

  .empty-body {
    font-family: var(--font-fell);
    font-style: italic;
    font-size: 1.6rem;
    line-height: 1.8;
    color: var(--ochre);
    max-width: 36rem;
    margin-bottom: 2.5rem;
  }

  /* RESPONSIVE */
  @media (max-width: 480px) {
    .empty-headline { font-size: 3rem; }
    .empty-body { font-size: 1.4rem; }
    .empty-state { padding: 2rem 0 4rem; }
  }
</style>