---

<Base title="Work" activePage="work">
  <div class="page-content">
    <div class="page-header">
      <h2 class="page-title">Work</h2>
      <div class="page-rule"></div>
      <span class="page-sub">{projects.length} projects</span>
    </div>

    <div class="catalog-wrapper">
      <div class="catalog-tabs">
        <button class="catalog-tab active" data-filter="all">All</button>
        <button class="catalog-tab" data-filter="web">Web</button>
        <button class="catalog-tab" data-filter="graphic">Graphic</button>
        <button class="catalog-tab" data-filter="print">Print</button>
      </div>

      <div class="catalog-body">
        <div class="works-grid" id="works-grid">
          {
            projects.map((project) => (
              <>
                <div
                  class="work-card"
                  data-type={project.type}
                  data-id={project.id}
                >
                  <div class="work-thumb">
                    <span
                      class={`work-tag ${project.kind === "case-study" ? "tag-case-study" : "tag-gallery"}`}
                    >
                      {project.kind === "case-study" ? "Case study" : "Gallery"}
                    </span>
                    <img src={project.thumb} alt={project.title} />
                  </div>
                  <div class="work-card-meta">
                    <span class="work-card-title">{project.title}</span>
                    <span class="work-card-type">{project.type}</span>
                  </div>
                  <div class="work-card-hint">
                    {project.kind === "case-study"
                      ? "Click to read more"
                      : "View images"}
                  </div>
                </div>

                <div
                  class="expanded-panel"
                  id={project.id}
                  data-total={project.slides.length}
                >
                  <div class="panel-header">
                    <div>
                      <div class="panel-title">{project.title}</div>
                      <div class="panel-meta">
                        {project.type} &nbsp;·&nbsp;{" "}
                        {project.kind === "case-study"
                          ? "Case study"
                          : "Gallery"}
                      </div>
                    </div>
                    <button
                      class="close-btn stamp stamp-accent"
                      data-close={project.id}
                    >
                      Close ✕
                    </button>
                  </div>

                  <div class="carousel" id={`carousel-${project.id}`}>
                    {project.slides.map((slide, i) =>
                      project.kind === "case-study" ? (
                        <div class={`cs-slide${i === 0 ? " active" : ""}`}>
                          <div class="slide-image">
                            <img src={slide.image} alt={slide.alt} />
                          </div>
                          <div class="slide-content">
                            <div>
                              <div class="slide-section-label">
                                {(slide as CaseStudySlide).label}
                              </div>
                              <div class="slide-heading">
                                {(slide as CaseStudySlide).heading}
                              </div>
                              <div class="slide-text">
                                {(slide as CaseStudySlide).body}
                              </div>
                            </div>
                            {i === 0 && project.tools && (
                              <div class="slide-tools">
                                {project.tools.map((tool) => (
                                  <span class="slide-tool">{tool}</span>
                                ))}
                              </div>
                            )}
                          </div>
                        </div>
                      ) : project.kind === "gallery" ? (
                        <div class={`gl-slide${i === 0 ? " active" : ""}`}>
                          <div class="gl-image">
                            <img src={slide.image} alt={slide.alt} />
                          </div>
                          <div class="gl-caption">
                            {(slide as GallerySlide).caption}
                          </div>
                        </div>
                      ) : project.kind === "scroll-gallery" ? (
                        <div class={`scroll-slide${i === 0 ? " active" : ""}`}>
                          <div class="scroll-image">
                            <img src={slide.image} alt={slide.alt} />
                          </div>
                          <div class="gl-caption">
                            {(slide as ScrollSlide).caption}
                            {i === 0 && (
                              <span class="scroll-hint">
                                ↕ Scroll to explore
                              </span>
                            )}
                          </div>
                        </div>
                      ) : null,
                    )}
                  </div>

                  <div class="carousel-nav">
                    <div class="stamp-nav">
                      <button
                        class="stamp-btn stamp stamp-ink prev-btn"
                        data-panel={project.id}
                        disabled
                      >
                        ← Prev
                      </button>
                      <button
                        class="stamp-btn stamp stamp-ink next-btn"
                        data-panel={project.id}
                      >
                        Next →
                      </button>
                    </div>
                    <div
                      class="slide-counter stamp stamp-muted"
                      id={`counter-${project.id}`}
                    >
                      1 / {project.slides.length}
                    </div>
                  </div>
                </div>
              </>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .page-content {
    padding: 4rem 0;
  }

  /* CATALOG TABS */
  .catalog-wrapper {
    position: relative;
  }

  .catalog-tabs {
    display: flex;
    align-items: flex-end;
    gap: 0;
    position: relative;
  }

  .catalog-tab {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0 1.6rem;
    cursor: pointer;
    white-space: nowrap;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      filter 0.12s,
      transform 0.12s;
    border-radius: 0.6rem 0.6rem 0 0;
    border: 0.15rem solid rgba(0, 0, 0, 0.25);
    border-bottom: none;
    margin-right: -0.15rem;
  }

  .catalog-tab:nth-child(1) {
    background: var(--tab-all);
    color: var(--tab-all-txt);
    height: 3.2rem;
    z-index: 1;
    box-shadow:
      -0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.08),
      0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.06);
  }
  .catalog-tab:nth-child(2) {
    background: var(--tab-web);
    color: var(--tab-web-txt);
    height: 3.8rem;
    z-index: 2;
    box-shadow:
      -0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.12),
      0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.08);
  }
  .catalog-tab:nth-child(3) {
    background: var(--tab-graphic);
    color: var(--tab-graphic-txt);
    height: 4.4rem;
    z-index: 3;
    box-shadow:
      -0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.12),
      0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.08);
  }
  .catalog-tab:nth-child(4) {
    background: var(--tab-print);
    color: var(--tab-print-txt);
    height: 5rem;
    z-index: 4;
    box-shadow:
      -0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.12),
      0.2rem -0.2rem 0.4rem rgba(0, 0, 0, 0.08);
  }

  .catalog-tab.active {
    z-index: 10;
    filter: brightness(1.08);
    transform: translateY(-0.2rem);
  }

  .catalog-tab.active::after {
    content: "";
    position: absolute;
    bottom: -0.2rem;
    left: 0;
    right: 0;
    height: 0.3rem;
    background: inherit;
    z-index: 11;
  }

  .catalog-tab:not(.active):hover {
    filter: brightness(1.1);
  }

  .catalog-body {
    background-color: #ede6d3;
    background-image: url("/images/textures/cardboard.png");
    background-repeat: repeat;
    background-blend-mode: lighten;
    border: 0.15rem solid rgba(44, 32, 21, 0.3);
    padding: 1.75rem;
    position: relative;
    z-index: 0;
    box-shadow:
      inset 0 0.3rem 0.6rem rgba(44, 32, 21, 0.06),
      inset 0 -0.1rem 0 rgba(44, 32, 21, 0.08),
      0 0.4rem 1.2rem rgba(44, 32, 21, 0.12),
      0 0.1rem 0.3rem rgba(44, 32, 21, 0.08);
  }

  .catalog-body::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/textures/cardboard.png");
    background-repeat: repeat;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }

  .catalog-body > * {
    position: relative;
    z-index: 1;
  }

  /* GRID */
  .works-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  .work-card {
    cursor: pointer;
  }

  .work-thumb {
    background: rgba(44, 32, 21, 0.05);
    border: 0.1rem solid rgba(44, 32, 21, 0.1);
    aspect-ratio: 3/2;
    overflow: hidden;
    margin-bottom: 0.75rem;
    position: relative;
    transition: border-color 0.15s;
  }

  .work-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .work-card:hover .work-thumb {
    border-color: var(--accent);
  }
  .work-card:hover .work-card-title {
    color: var(--accent);
  }

  .work-tag {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    z-index: 1;
  }

  .tag-case-study {
    background: var(--accent);
    color: var(--paper);
  }
  .tag-gallery {
    background: rgba(139, 107, 61, 0.15);
    color: var(--ochre);
    border: 0.1rem solid rgba(139, 107, 61, 0.3);
  }

  .work-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.2rem;
  }
  .work-card-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--ink);
    transition: color 0.15s;
  }
  .work-card-type {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ochre);
  }
  .work-card-hint {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: rgba(44, 32, 21, 0.3);
  }

  /* EXPANDED PANEL */
  .expanded-panel {
    grid-column: 1 / -1;
    border: 0.15rem solid rgba(44, 32, 21, 0.3);
    background: rgba(44, 32, 21, 0.02);
    display: none;
    animation: fadeIn 0.2s ease;
    margin-top: 0.25rem;
  }

  .expanded-panel.open {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-0.4rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 0.1rem solid var(--rule);
  }
  .panel-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.3rem;
  }
  .panel-meta {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .close-btn {
    cursor: pointer;
    background: none;
    font-size: 1rem;
    padding: 0.5rem 1.1rem;
    transition: all 0.1s;
  }
  .close-btn:hover {
    filter: opacity(1);
  }

  /* CAROUSEL — fixed height via visibility trick */
  .carousel {
    position: relative;
  }

  .cs-slide {
    display: grid;
    grid-template-columns: 1fr 1fr;
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .cs-slide.active {
    visibility: visible;
    position: relative;
    pointer-events: auto;
  }

  .gl-slide {
    display: flex;
    flex-direction: column;
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .gl-slide.active {
    visibility: visible;
    position: relative;
    pointer-events: auto;
  }

  .scroll-slide {
    display: flex;
    flex-direction: column;
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .scroll-slide.active {
    visibility: visible;
    position: relative;
    pointer-events: auto;
  }

  .scroll-image {
    aspect-ratio: 16/9;
    overflow-y: scroll;
    overflow-x: hidden;
    border-bottom: 0.1rem solid var(--rule);
    cursor: ns-resize;
  }

  .scroll-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .scroll-hint {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: rgba(44, 32, 21, 0.35);
    margin-left: 1rem;
  }

  .slide-image {
    background: rgba(44, 32, 21, 0.07);
    border-right: 0.1rem solid var(--rule);
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .slide-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slide-content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .slide-section-label {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .slide-heading {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }
  .slide-text {
    font-size: 1.3rem;
    line-height: 1.85;
    color: var(--ink-light);
    font-style: italic;
    flex: 1;
  }
  .slide-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .slide-tool {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--ink);
    border: 0.1rem solid var(--rule);
    padding: 0.3rem 0.8rem;
  }

  .gl-image {
    background: rgba(44, 32, 21, 0.07);
    border-bottom: 0.1rem solid var(--rule);
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .gl-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gl-caption {
    padding: 1rem 1.5rem;
    font-size: 1.3rem;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.7;
  }

  /* CAROUSEL NAV */
  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.5rem;
    border-top: 0.1rem solid var(--rule);
    background: rgba(44, 32, 21, 0.015);
  }
  .stamp-nav {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .stamp-btn {
    font-size: 1.1rem;
    padding: 0.4rem 1.2rem;
    cursor: pointer;
    background: none;
    transition: all 0.1s;
  }
  .stamp-btn.prev-btn {
    transform: rotate(0.4deg);
  }
  .stamp-btn.next-btn {
    transform: rotate(-0.3deg);
  }
  .stamp-btn:hover:not(:disabled) {
    filter: opacity(1);
  }
  .stamp-btn:active:not(:disabled) {
    transform: translate(0.1rem, 0.1rem);
  }
  .stamp-btn:disabled {
    filter: opacity(0.25);
    cursor: default;
  }
  .slide-counter {
    font-size: 1.1rem;
    padding: 0.3rem 1rem;
    transform: rotate(0.3deg);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .catalog-tab {
      font-size: 0.9rem;
      padding: 0 2rem;
    }
    .catalog-tab:nth-child(1) {
      height: 3.2rem;
    }
    .catalog-tab:nth-child(2) {
      height: 3.8rem;
    }
    .catalog-tab:nth-child(3) {
      height: 4.4rem;
    }
    .catalog-tab:nth-child(4) {
      height: 5rem;
    }

    .catalog-body {
      padding: 1.25rem;
    }

    .cs-slide {
      grid-template-columns: 1fr;
    }

    .slide-image {
      border-right: none;
      border-bottom: 0.1rem solid var(--rule);
      aspect-ratio: 16/9;
    }

    .panel-header {
      flex-wrap: wrap;
      gap: 1rem;
    }
    .slide-content {
      min-height: 18rem;
      max-height: 18rem;
      overflow-y: auto;
    }

    .gl-caption {
      min-height: 6rem;
      max-height: 6rem;
      overflow-y: auto;
    }
  }

  @media (max-width: 480px) {
    .works-grid {
      grid-template-columns: 1fr;
    }

    .catalog-tab {
      font-size: 1rem;
      padding: 0 1.6rem;
      letter-spacing: 0.08em;
    }
    .catalog-tab:nth-child(1) {
      height: 3.4rem;
    }
    .catalog-tab:nth-child(2) {
      height: 4rem;
    }
    .catalog-tab:nth-child(3) {
      height: 4.6rem;
    }
    .catalog-tab:nth-child(4) {
      height: 5.2rem;
    }

    .catalog-body {
      padding: 1rem;
    }

    .panel-title {
      font-size: 1.6rem;
    }
    .stamp-btn {
      font-size: 0.9rem;
      padding: 0.4rem 0.8rem;
    }
    .slide-counter {
      font-size: 0.9rem;
    }
    .carousel-nav {
      padding: 0.75rem 1rem;
    }
  }
</style>

<script>
  const state: Record<string, number> = {};

  function getSlides(panelId: string) {
    const carousel = document.getElementById(`carousel-${panelId}`);
    return carousel
      ? Array.from(
          carousel.querySelectorAll(".cs-slide, .gl-slide, .scroll-slide"),
        )
      : [];
  }

  function goTo(panelId: string, idx: number) {
    const slides = getSlides(panelId);
    slides.forEach((s) => s.classList.remove("active"));
    slides[idx]?.classList.add("active");
    state[panelId] = idx;

    const counter = document.getElementById(`counter-${panelId}`);
    if (counter) counter.textContent = `${idx + 1} / ${slides.length}`;

    const panel = document.getElementById(panelId);
    if (!panel) return;
    const prevBtn = panel.querySelector(".prev-btn") as HTMLButtonElement;
    const nextBtn = panel.querySelector(".next-btn") as HTMLButtonElement;
    if (prevBtn) prevBtn.disabled = idx === 0;
    if (nextBtn) nextBtn.disabled = idx === slides.length - 1;
  }

  function openPanel(panelId: string) {
    document
      .querySelectorAll(".expanded-panel.open")
      .forEach((el) => el.classList.remove("open"));
    const panel = document.getElementById(panelId);
    if (!panel) return;
    panel.classList.add("open");
    goTo(panelId, 0);
    setTimeout(
      () => panel.scrollIntoView({ behavior: "smooth", block: "nearest" }),
      50,
    );
  }

  function closePanel(panelId: string) {
    document.getElementById(panelId)?.classList.remove("open");
  }

  document.querySelectorAll(".work-card").forEach((card) => {
    card.addEventListener("click", () => {
      const id = (card as HTMLElement).dataset.id;
      if (!id) return;
      const panel = document.getElementById(id);
      if (panel?.classList.contains("open")) {
        closePanel(id);
      } else {
        openPanel(id);
      }
    });
  });

  document.querySelectorAll(".close-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.close;
      if (id) closePanel(id);
    });
  });

  document.querySelectorAll(".prev-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.panel;
      if (!id) return;
      const current = state[id] ?? 0;
      if (current > 0) goTo(id, current - 1);
    });
  });

  document.querySelectorAll(".next-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.panel;
      if (!id) return;
      const slides = getSlides(id);
      const current = state[id] ?? 0;
      if (current < slides.length - 1) goTo(id, current + 1);
    });
  });

  const hash = window.location.hash.slice(1);
  if (hash) {
    const panel = document.getElementById(hash);
    if (panel?.classList.contains("expanded-panel")) {
      openPanel(hash);
    }
  }

  document.querySelectorAll(".catalog-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      document
        .querySelectorAll(".catalog-tab")
        .forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");
      const filter = (tab as HTMLElement).dataset.filter;
      document
        .querySelectorAll(".expanded-panel.open")
        .forEach((el) => el.classList.remove("open"));
      document.querySelectorAll(".work-card").forEach((card) => {
        const type = (card as HTMLElement).dataset.type;
        (card as HTMLElement).style.display =
          filter === "all" || type === filter ? "" : "none";
      });
    });
  });
</script>
