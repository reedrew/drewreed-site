---
import Base from "../layouts/Base.astro";

const designTools = [
    "Figma",
    "Illustrator",
    "InDesign",
    "Photoshop",
    "Affinity",
    "Typography",
    "Print design",
    "Brand identity",
];
const webTools = [
    "HTML",
    "CSS",
    "JavaScript",
    "WordPress",
    "Wix",
    "React",
    "Astro",
    "Tailwind",
    "Knowledge Management",
];
---

<Base title="About" activePage="about">
    <div class="page-content">
        <div class="page-header">
            <h2 class="page-title">About</h2>
            <div class="page-rule"></div>
        </div>

        <div class="about-grid">
            <div class="about-left">
                <div class="photo-wrap">
                    <img
                        src="/images/site-portrait.webp"
                        alt="Drew Reed"
                        class="photo"
                    />
                </div>
                <a
                    href="/drew-reed-resume.pdf"
                    class="resume-link stamp stamp-accent"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <rect
                            x="1"
                            y="1"
                            width="10"
                            height="10"
                            rx="1"
                            stroke="currentColor"
                            stroke-width="1.2"></rect>
                        <path
                            d="M3 5h6M3 7h4"
                            stroke="currentColor"
                            stroke-width="1.2"
                            stroke-linecap="round"></path>
                    </svg>
                    Download résumé
                </a>
                <div class="resume-note">PDF · Updated 2026</div>
            </div>

            <div class="about-right">
                <div class="bio-section">
                    <div class="section-label">Bio</div>
                    <div class="bio-text">
                        <p>
                            Hey! I'm Drew. I'm a graphic and web designer based
                            in Indy.
                        </p>
                        <p>
                            My background spans traditional print and graphics
                            work to web development. I went to IU Bloomington
                            and studied Graphic Design and Web Design, where I
                            graduated with high distinction.
                        </p>
                        <p>
                            My goal is to serve primarily businesses in the
                            Indianapolis area. A modern website is a necessity
                            for a successful business today, and I want my
                            community to thrive.
                        </p>
                    </div>
                </div>

                <div class="skills-section">
                    <div class="section-label">Skills &amp; tools</div>
                    <div class="skills-group">
                        <div class="skills-group-label">Design</div>
                        <div class="skills-list">
                            {
                                designTools.map((tool) => (
                                    <span class="skill-tag">{tool}</span>
                                ))
                            }
                        </div>
                    </div>
                    <div class="skills-group">
                        <div class="skills-group-label">Web</div>
                        <div class="skills-list">
                            {
                                webTools.map((tool) => (
                                    <span class="skill-tag">{tool}</span>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Base>

<style>
    .page-content {
        padding: 4rem 0;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 4rem;
        align-items: start;
    }

    .photo-wrap {
        /*border: 0.1rem solid rgba(44, 32, 21, 0.12);*/
        aspect-ratio: 3/4;
        overflow: hidden;
        margin-bottom: 1.5rem;
        background: rgba(44, 32, 21, 0.04);
        box-shadow:
            0 0.5rem 1.2rem rgba(44, 32, 21, 0.14),
            0 0.15rem 0.3rem rgba(44, 32, 21, 0.08);
    }

    .photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
        border: 12px solid white;
    }

    .resume-link {
        display: flex;
        width: 100%;
        border: 4px solid var(--accent);
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        font-family: var(--font-serif);
        font-size: 1.2rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        color: var(--accent);
        text-decoration: none;
        text-transform: uppercase;
        padding: 1rem 1rem 0.5rem;
        margin-bottom: 0.75rem;
        transition: all 0.15s;
        box-shadow:
            0 0.5rem 1.2rem rgba(44, 32, 21, 0.25),
            0 0.15rem 0.3rem rgba(44, 32, 21, 0.15);
    }

    .resume-link:hover {
        transform: scale(1.02);
        box-shadow:
            0 0.9rem 1.2rem rgba(44, 32, 21, 0.25),
            0 0.45rem 0.3rem rgba(44, 32, 21, 0.15);
    }

    .resume-link:active {
        box-shadow: none;
        background: var(--accent);
        color: var(--paper);
        scale: 0.99;
    }

    .resume-link > svg {
        transform: translateY(-3px);
    }

    .resume-note {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(44, 32, 21, 0.35);
        text-align: center;
    }

    .bio-section {
        margin-bottom: 3rem;
    }

    .bio-text {
        font-size: 1.4rem;
        line-height: 1.8;
        letter-spacing: 2%;
        color: var(--ink-light);
    }
    .bio-text p + p {
        margin-top: 1.25rem;
    }

    .skills-section {
        margin-bottom: 3rem;
    }
    .skills-group {
        margin-bottom: 1.75rem;
    }

    .skills-group-label {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ochre);
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 0.1rem solid var(--rule);
    }

    .skills-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .skill-tag {
        font-family: var(--font-mono);
        font-size: 1rem;
        letter-spacing: 0.08em;
        color: var(--ink);
        border: 0.1rem solid rgba(44, 32, 21, 0.25);
        padding: 0.4rem 1rem;
        background: rgba(44, 32, 21, 0.03);
        transition: all 0.15s;
        cursor: default;
    }

    .skill-tag:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-light);
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }

        .photo-wrap {
            aspect-ratio: 1;
            max-width: 28rem;
        }

        .resume-link {
            max-width: 28rem;
        }
        .resume-note {
            max-width: 28rem;
        }
    }

    @media (max-width: 480px) {
        .bio-text {
            font-size: 1.4rem;
        }
        .photo-wrap {
            max-width: 100%;
        }
        .resume-link {
            max-width: 100%;
        }
    }
</style>
